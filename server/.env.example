# Copy this file to .env and fill in your values

SECRET_KEY=your-random-secret-key-here
MONGO_URI=mongodb://localhost:27017/madurai_civic_db
JWT_SECRET=your-random-jwt-secret-here
JWT_EXPIRATION_HOURS=24

# Blockchain (Ganache - local only, simulation fallback works without it)
BLOCKCHAIN_RPC_URL=http://127.0.0.1:7545
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
GANACHE_ACCOUNT=your-ganache-account
GANACHE_PRIVATE_KEY=your-ganache-private-key

# Email (optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# App
FLASK_ENV=development
DEBUG=True
UPLOAD_FOLDER=../uploads
MAX_CONTENT_LENGTH=16777216

# Frontend URL (for CORS - set in Render dashboard)
FRONTEND_URL=https://madurai-civic-system.vercel.app/
